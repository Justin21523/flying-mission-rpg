# Kept tracked on purpose: docs/ and public/models/ (design source-of-truth + game models).

# Large user-dropped binary asset packs are NOT version-controlled — the folders + their README /
# .gitkeep stay tracked so the drop-in contract is documented (see LLM_PROVIDER.md "Asset auto-discovery").
docs
src/assets/**/*.glb
src/assets/**/*.gltf
src/assets/**/*.bin
src/assets/**/*.jpg
src/assets/**/*.jpeg
src/assets/**/*.png
src/assets/**/*.webp
src/assets/**/*.avif
src/assets/**/*.ktx2
src/assets/**/*.basis
src/assets/**/*.hdr
public/textures/**
public/materials/**
public/models/**
public/hdri/**
!**/README.md
!**/.gitkeep
